{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/main.py": {
      "excludeFiles": "{saaf.db,saaf.db-*,scripts/**,.venv/**,.pytest_cache/**,.ruff_cache/**,**/__pycache__/**,**/*.pyc,*.db}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/app/main.py" }
  ]
}
